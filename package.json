{
  "name": "new-maropost",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o dist-storybook",
    "tokens:build": "node src/design-tokens/build.mjs",
    "tokens:watch": "node src/design-tokens/build.mjs --watch",
    "type-check": "vue-tsc -b --noEmit",
    "design-kit:dev": "cd design-kit && npm run dev",
    "design-kit:build": "cd design-kit && npm run build",
    "design-kit:export-figma": "node design-kit/scripts/export-figma.mjs",
    "design-kit:push-connect": "npx @figma/code-connect publish --token $FIGMA_TOKEN",
    "design-kit:push-variables": "node design-kit/scripts/push-variables.mjs",
    "tokens:sync-figma": "node design-kit/scripts/sync-from-figma.mjs && npm run tokens:build",
    "tokens:push-figma": "node src/design-tokens/build.mjs --push-figma"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "pinia": "^3.0.4",
    "vue": "^3.5.25",
    "vue-router": "^5.0.3",
    "vuetify": "^3.12.2"
  },
  "devDependencies": {
    "@mdx-js/react": "^3.1.1",
    "@storybook/addon-docs": "9.1.20",
    "@storybook/addon-themes": "9.1.20",
    "@storybook/react-dom-shim": "9.1.20",
    "@storybook/vue3": "9.1.20",
    "@storybook/vue3-vite": "9.1.20",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sass": "^1.97.3",
    "storybook": "9.1.20",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-tsc": "^3.1.5"
  },
  "packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48"
}
