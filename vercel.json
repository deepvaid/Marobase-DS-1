{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm run build && pnpm run build-storybook && cp -r dist-storybook dist/storybook",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/storybook/:path*", "destination": "/storybook/:path*" },
    { "source": "/((?!storybook|assets).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
