{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run tokens:build && npm run build && npm run build-storybook",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/storybook/:path*", "destination": "/storybook/:path*" },
    { "source": "/((?!storybook|assets).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
