{
  "$type": "designTokens",
  "$version": "1.0.0",
  "$description": "Maropost Design System — Single source of truth for all design values. Compatible with Tokens Studio (Figma) and Style Dictionary.",

  "spacing": {
    "$description": "4px base spacing scale",
    "1":  { "$value": "4px",  "$type": "dimension" },
    "2":  { "$value": "8px",  "$type": "dimension" },
    "3":  { "$value": "12px", "$type": "dimension" },
    "4":  { "$value": "16px", "$type": "dimension" },
    "5":  { "$value": "20px", "$type": "dimension" },
    "6":  { "$value": "24px", "$type": "dimension" },
    "7":  { "$value": "28px", "$type": "dimension" },
    "8":  { "$value": "32px", "$type": "dimension" },
    "10": { "$value": "40px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension" },
    "16": { "$value": "64px", "$type": "dimension" }
  },

  "borderRadius": {
    "$description": "Border radius scale",
    "sm": { "$value": "4px",  "$type": "dimension" },
    "md": { "$value": "8px",  "$type": "dimension" },
    "lg": { "$value": "12px", "$type": "dimension" },
    "xl": { "$value": "16px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },

  "shadow": {
    "$description": "Elevation shadows — flat design preferred, use sparingly",
    "sm":  { "$value": "0 1px 3px rgba(0, 0, 0, 0.06)",  "$type": "shadow" },
    "md":  { "$value": "0 4px 16px rgba(0, 0, 0, 0.08)", "$type": "shadow" },
    "lg":  { "$value": "0 8px 32px rgba(0, 0, 0, 0.1)",  "$type": "shadow" }
  },

  "transition": {
    "$description": "Animation durations",
    "fast": { "$value": "0.15s ease", "$type": "transition" },
    "base": { "$value": "0.2s ease",  "$type": "transition" }
  },

  "color": {
    "$description": "Semantic color palette — light theme",
    "light": {
      "background":         { "$value": "#F9FAFB", "$type": "color" },
      "surface":            { "$value": "#FFFFFF", "$type": "color" },
      "surfaceVariant":     { "$value": "#F3F4F6", "$type": "color" },
      "onSurfaceVariant":   { "$value": "#6B7280", "$type": "color" },
      "primary":            { "$value": "#1A56DB", "$type": "color" },
      "primaryDarken":      { "$value": "#1447B8", "$type": "color" },
      "secondary":          { "$value": "#7E3AF2", "$type": "color" },
      "secondaryDarken":    { "$value": "#6627CC", "$type": "color" },
      "success":            { "$value": "#0E9F6E", "$type": "color" },
      "successDarken":      { "$value": "#057A55", "$type": "color" },
      "warning":            { "$value": "#D97706", "$type": "color" },
      "warningDarken":      { "$value": "#B45309", "$type": "color" },
      "error":              { "$value": "#E02424", "$type": "color" },
      "errorDarken":        { "$value": "#C81E1E", "$type": "color" },
      "info":               { "$value": "#1A56DB", "$type": "color" },
      "onPrimary":          { "$value": "#FFFFFF", "$type": "color" },
      "onSecondary":        { "$value": "#FFFFFF", "$type": "color" },
      "onSuccess":          { "$value": "#FFFFFF", "$type": "color" },
      "onError":            { "$value": "#FFFFFF", "$type": "color" },
      "onWarning":          { "$value": "#FFFFFF", "$type": "color" },
      "border":             { "$value": "#E5E7EB", "$type": "color" },
      "textPrimary":        { "$value": "#111928", "$type": "color" },
      "textMuted":          { "$value": "#6B7280", "$type": "color" }
    },
    "dark": {
      "background":         { "$value": "#111928", "$type": "color" },
      "surface":            { "$value": "#1F2937", "$type": "color" },
      "surfaceVariant":     { "$value": "#374151", "$type": "color" },
      "onSurfaceVariant":   { "$value": "#9CA3AF", "$type": "color" },
      "primary":            { "$value": "#60A5FA", "$type": "color" },
      "primaryDarken":      { "$value": "#3B82F6", "$type": "color" },
      "secondary":          { "$value": "#A78BFA", "$type": "color" },
      "secondaryDarken":    { "$value": "#8B5CF6", "$type": "color" },
      "success":            { "$value": "#34D399", "$type": "color" },
      "warning":            { "$value": "#FBBF24", "$type": "color" },
      "error":              { "$value": "#F87171", "$type": "color" },
      "info":               { "$value": "#60A5FA", "$type": "color" },
      "onPrimary":          { "$value": "#111928", "$type": "color" },
      "border":             { "$value": "#374151", "$type": "color" },
      "textPrimary":        { "$value": "#F9FAFB", "$type": "color" },
      "textMuted":          { "$value": "#9CA3AF", "$type": "color" }
    },
    "sidebar": {
      "$description": "Sidebar-specific dark palette",
      "bg":        { "$value": "#111928", "$type": "color" },
      "surface":   { "$value": "#1F2937", "$type": "color" },
      "border":    { "$value": "rgba(255, 255, 255, 0.07)", "$type": "color" },
      "text":      { "$value": "rgba(255, 255, 255, 0.75)", "$type": "color" },
      "textMuted": { "$value": "rgba(255, 255, 255, 0.5)",  "$type": "color" },
      "textFaint": { "$value": "rgba(255, 255, 255, 0.3)",  "$type": "color" },
      "hover":     { "$value": "rgba(255, 255, 255, 0.05)", "$type": "color" }
    }
  },

  "typography": {
    "$description": "Inter-based type scale",
    "fontFamily": {
      "base": { "$value": "Inter, system-ui, -apple-system, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "'JetBrains Mono', 'Fira Code', monospace",   "$type": "fontFamily" }
    },
    "fontSize": {
      "xs":    { "$value": "11px", "$type": "dimension" },
      "sm":    { "$value": "12px", "$type": "dimension" },
      "body":  { "$value": "14px", "$type": "dimension" },
      "md":    { "$value": "16px", "$type": "dimension" },
      "lg":    { "$value": "18px", "$type": "dimension" },
      "xl":    { "$value": "22px", "$type": "dimension" },
      "2xl":   { "$value": "28px", "$type": "dimension" },
      "3xl":   { "$value": "36px", "$type": "dimension" }
    },
    "fontWeight": {
      "regular":  { "$value": "400", "$type": "fontWeight" },
      "medium":   { "$value": "500", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" },
      "bold":     { "$value": "700", "$type": "fontWeight" }
    },
    "lineHeight": {
      "tight":  { "$value": "1.2", "$type": "number" },
      "normal": { "$value": "1.5", "$type": "number" },
      "loose":  { "$value": "1.75", "$type": "number" }
    }
  },

  "layout": {
    "$description": "Fixed layout dimensions",
    "sidebarWidth":    { "$value": "260px", "$type": "dimension" },
    "sidebarRailWidth":{ "$value": "72px",  "$type": "dimension" },
    "appbarHeight":    { "$value": "56px",  "$type": "dimension" },
    "drawerWidth":     { "$value": "480px", "$type": "dimension" },
    "searchMaxWidth":  { "$value": "360px", "$type": "dimension" },
    "contentMaxWidth": { "$value": "1280px","$type": "dimension" }
  }
}
